# URL de conexión a PostgreSQL.
# Formato: postgresql://usuario:password@host:puerto/nombre_base_de_datos
# En local: copia este archivo a ".env" y pon aquí los datos de tu Postgres local.
# En Render: no uses este archivo, configura DATABASE_URL como variable de entorno
# en el dashboard del servicio (con el valor "Internal Database URL" que te da Render).
DATABASE_URL=postgresql://usuario:password@localhost:5432/quicnote
